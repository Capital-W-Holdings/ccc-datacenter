# CCC Summit Intelligence - Client Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# LOCAL DEVELOPMENT (leave empty to use Vite proxy)
# ============================================
# VITE_API_URL=
# VITE_WS_URL=

# ============================================
# PRODUCTION (Vercel) - Set these in Vercel Dashboard
# ============================================
# API URL - Your backend server URL (e.g., Railway/Render)
# Example: https://ccc-datacenter-server.up.railway.app
VITE_API_URL=http://localhost:3001

# WebSocket URL (optional - defaults to VITE_API_URL if not set)
VITE_WS_URL=http://localhost:3001

# API Key for authentication (must match server's APP_SECRET)
VITE_APP_SECRET=your-random-secret-key-at-least-32-chars

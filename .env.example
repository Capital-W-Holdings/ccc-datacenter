# CCC Summit Intelligence - Environment Variables
# Copy this file to .env and fill in the values

# ===========================
# REQUIRED: Supabase Configuration
# ===========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ===========================
# SECURITY CONFIGURATION
# ===========================

# App Secret - Required for API authentication
# Generate with: openssl rand -hex 32
APP_SECRET=your-secret-key-here

# Encryption Key - Required for encrypting sensitive data (API keys)
# Must be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-character-hex-encryption-key

# ===========================
# OPTIONAL: API Keys
# ===========================

# Anthropic API Key (can also be set via Settings UI)
# Will be encrypted at rest when stored in database
ANTHROPIC_API_KEY=sk-ant-...

# ===========================
# SERVER CONFIGURATION
# ===========================
PORT=3001
NODE_ENV=development

# CORS origin for production (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Logging level: debug, info, warn, error
LOG_LEVEL=debug

# ===========================
# REDIS (Required for job queue)
# ===========================
REDIS_URL=redis://localhost:6379

# ===========================
# RATE LIMITING
# ===========================
# Override default rate limits (requests per window)
# RATE_LIMIT_GLOBAL=100
# RATE_LIMIT_SCRAPER=5
# RATE_LIMIT_ENRICHMENT=20
# RATE_LIMIT_STRICT=10

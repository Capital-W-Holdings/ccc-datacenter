# CCC Summit Intelligence - Server Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Supabase
# ===========================================
# Get these from your Supabase project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================
# REQUIRED - Redis (for background jobs)
# ===========================================
# Without Redis, scrapers/enrichment/exports won't work!
# Local: redis://localhost:6379
# Upstash: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ===========================================
# REQUIRED - API Security
# ===========================================
# Random string, at least 32 characters
# Generate with: openssl rand -hex 32
APP_SECRET=your-random-secret-key-at-least-32-chars

# ===========================================
# OPTIONAL - Encryption
# ===========================================
# Used to encrypt sensitive data (like API keys) in database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ===========================================
# OPTIONAL - Brave Search API (for AI Research)
# ===========================================
# Get one at: https://brave.com/search/api/
# Required for the AI Research feature to search the web
BRAVE_SEARCH_API_KEY=

# ===========================================
# OPTIONAL - Server Config
# ===========================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
